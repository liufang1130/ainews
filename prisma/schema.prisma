// Prisma Schema for AI News Aggregation Platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 信息源表 ====================
model Source {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   // website, wechat, github, twitter, producthunt, hackernews, reddit
  description String?
  config      String?  // JSON: 爬取规则配置 {selectors: {...}, headers: {...}}
  isEnabled   Boolean  @default(true)
  priority    Int      @default(0)
  lastCrawledAt DateTime?
  status      String   @default("active") // active, error, disabled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rawArticles RawArticle[]
  crawlLogs   CrawlLog[]
}

// ==================== 原始抓取表 ====================
model RawArticle {
  id           String   @id @default(cuid())
  sourceId     String
  source       Source   @relation(fields: [sourceId], references: [id])
  title        String
  summary      String?
  content      String?
  url          String   @unique
  coverImage   String?
  publishedAt  DateTime?
  author       String?
  fingerprint  String?  // 用于去重的hash
  status       String   @default("pending") // pending, approved, rejected, published
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article     Article?
  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
}

// ==================== 已发布文章表（前台展示） ====================
model Article {
  id            String   @id @default(cuid())
  rawArticleId  String   @unique
  rawArticle    RawArticle @relation(fields: [rawArticleId], references: [id])
  title         String
  summary       String?
  content       String?
  sourceName    String?
  sourceUrl     String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  tags          String?  // JSON array string
  coverImage    String?
  isPinned      Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@index([publishedAt])
  @@index([isPinned])
}

// ==================== 分类表 ====================
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?  // emoji or icon name
  color       String?  // hex color for tag
  sortOrder   Int      @default(0)
  description String?

  articles    Article[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 爬取日志 ====================
model CrawlLog {
  id          String   @id @default(cuid())
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  status      String   // success, error, partial
  itemsFound  Int      @default(0)
  itemsNew    Int      @default(0)
  errorMessage String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  @@index([sourceId])
  @@index([startedAt])
}
